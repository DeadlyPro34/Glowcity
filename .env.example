# Copy this file to ".env" and fill in your values.
# NEVER commit .env to Git.

# Flask sessions (required) — use a long random string
FLASK_SECRET_KEY=change-me-to-a-long-random-string

# Google Sign-In — OAuth Client ID from Google Cloud Console
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com

# Admin dashboard login
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-me

# Resend email (optional — resolution emails when status is Resolved)
RESEND_API_KEY=
RESEND_FROM_EMAIL=onboarding@resend.dev

# AI photo validation (set false on Render free tier)
ENABLE_AI=true
